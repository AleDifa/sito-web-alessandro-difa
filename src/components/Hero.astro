---
import LiquidEther from '../components/LiquidEther.jsx';
---

<section class="hero section section--tight-bottom">
  <div class="hero-bg">
    <LiquidEther
    client:only="react"
    colors={[ '#5227FF', '#FF9FFC', '#B497CF' ]}
    mouseForce={20}
    cursorSize={100}
    isViscous
    viscous={30}
    iterationsViscous={32}
    iterationsPoisson={32}
    resolution={0.5}
    isBounce={false}
    autoDemo
    autoSpeed={0.5}
    autoIntensity={2.2}
    takeoverDuration={0.25}
    autoResumeDelay={3000}
    autoRampDuration={0.6}
    ></LiquidEther>
  </div>

  <!-- Micro badge -->
  <span class="hero-badge">©2026</span>

  <div class="container">
    <div class="hero-inner">

      <h1 class="hero-title">
        <span class="title-line">WEB DESIGNER</span>
        <span class="title-line"><span class="hero-title-accent">&amp; Consulente SEO</span></span>
      </h1>

      <p class="hero-tagline">
        <span class="hero-slash">/</span> Ancona &amp; Marche
      </p>

      <p class="hero-desc">
        Realizzo siti web e landing page per PMI con tecniche SEO e GEO per far parlare di te l'AI
        e modelli 3D. Trasformo le visite in clienti reali per una presenza online
        che converte.
      </p>

    </div>
  </div>

</section>


<style>
  /* 1. La sezione Hero gestisce solo la sua altezza e lo sfondo */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Gestione eventi del mouse (nessun override su padding/margini) */
  .hero .container {
    pointer-events: none;
  }
  .hero-inner {
    pointer-events: auto;
  }

  /* Lo sfondo prende tutto lo spazio */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* subtle grain for texture, keeps the black from looking flat/digital */
  .hero-grain {
    position: absolute;
    inset: 0;
    opacity: 0.04;
  }


  /* ---------- 2026 ---------- */
  .hero-badge {
    position: absolute;
    right: 90px;
    z-index: 20;
    font-family: var(--font-display, inherit);
    font-weight: 800;
    font-size: 24px;
    letter-spacing: 0.02em;
    color: var(--accent, #3b82f6);
  }

  /* ---------- content ---------- */

  .container {
    position: relative;
    z-index: 2;
  }


  /* fa si che la scritta titolo, descrizione e tagline non sia tutta per orizzontale */
  .hero-inner {
    max-width: 720px;
  }


  .hero-title {
    font-family: var(--font-display, sans-serif);
    font-weight: 800;
    text-transform: uppercase;
    font-size: clamp(26px, 6vw, 86px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: #F5F3EE;
    margin: 0 0 28px;
  }

  .title-line { display: block; }

  .hero-title-accent {
    color: var(--accent, #3b82f6);
  }

  .hero-tagline {
    font-family: var(--font-serif, Georgia, 'Times New Roman', serif);
    font-style: italic;
    font-size: clamp(24px, 3.4vw, 38px);
    color: rgba(245,243,238,0.92);
    margin: 0 0 28px;
  }

  .hero-slash {
    font-style: normal;
    color: var(--accent, #3b82f6);
    margin-right: 6px;
  }

  .hero-desc {
    font-family: var(--font-body, inherit);
    color: rgba(245,243,238,0.6);
    font-size: clamp(15px, 1.8vw, 17px);
    line-height: 1.65;
    max-width: 420px;
    margin: 0;
  }



/* Stile per Mobile per il badge 2026 */
@media (max-width: 640px) {
  .hero-badge {
    right: 28px;
    bottom: 24px;    
    font-size: 24px;
  }
  .hero-title {
    font-size: clamp(30px,8vw, 46px);
    line-height: 1.1;
  }
  .hero-title-accent{
    font-size: clamp(29px,7vw, 44px);
    line-height: 1.1;
  }
  /* Trasforma ogni riga/parola in un blocco separato a capo */
  .title-line,
  .hero-title-accent {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>