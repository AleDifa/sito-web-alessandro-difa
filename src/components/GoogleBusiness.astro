---

<section class="section gb-section" id="google-business">
  <div class="gb-glow"></div>
  <div class="container">

    <div class="gb-header text-center">
      
      <h2 class="section-title" style="margin-bottom:16px;">
        <span class="text-maps">Google Maps: Intercetta per primo ogni possibile cliente nella tua zona</span>
      </h2>
    
    </div>



    <!-- Google Maps mock visual -->
    <div class="gb-visual">
      <div class="gb-map-mock">
        <div class="map-bg">
          <!-- Fake map roads -->
          <div class="map-road map-road-h" style="top:35%"></div>
          <div class="map-road map-road-h" style="top:60%"></div>
          <div class="map-road map-road-v" style="left:30%"></div>
          <div class="map-road map-road-v" style="left:65%"></div>
          <div class="map-road map-road-h thin" style="top:22%"></div>
          <div class="map-road map-road-h thin" style="top:75%"></div>
          <div class="map-road map-road-v thin" style="left:48%"></div>
        </div>
        <!-- Pin principale -->
        <div class="map-pin main-pin">
          <div class="pin-card">
            <div class="pin-card-header">
              <span class="pin-card-name">La Tua Attività</span>
              <span class="pin-card-rating">★ 4.9</span>
            </div>
            <span class="pin-card-cat">Primo su Google Maps</span>
          </div>
          <div class="pin-card-arrow"></div>
          <div class="pin-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
        </div>
        <!-- Pin secondari (concorrenti) -->
        <div class="map-pin secondary-pin" style="top:55%;left:20%">
          <div class="pin-icon-sm red"></div>
        </div>
        <div class="map-pin secondary-pin" style="top:65%;left:70%">
          <div class="pin-icon-sm red"></div>
        </div>
        <div class="map-pin secondary-pin" style="top:70%;left:55%">
          <div class="pin-icon-sm red"></div>
        </div>
      </div>

      <div class="gb-results">
        <div class="gbr-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#ea4335"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34a853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#fbbc05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.47 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#ea4335"/></svg>
          Google Maps
        </div>
        <div class="gbr-item gbr-item--first">
          <span class="gbr-pos">1°</span>
          <div>
            <div class="gbr-name">La Tua Attività</div>
            <div class="gbr-info">★★★★★ 4.9 · (128 recensioni)</div>
          </div>
          <span class="gbr-badge">Top</span>
        </div>
        <div class="gbr-item">
          <span class="gbr-pos muted">2°</span>
          <div>
            <div class="gbr-name muted">Concorrente A</div>
            <div class="gbr-info">★★★☆☆ 3.4 · (22 recensioni)</div>
          </div>
        </div>
        <div class="gbr-item">
          <span class="gbr-pos muted">3°</span>
          <div>
            <div class="gbr-name muted">Concorrente B</div>
            <div class="gbr-info">★★★★☆ 4.1 · (45 recensioni)</div>
          </div>
        </div>
      </div>
    </div>

 <p class="section-subtitle-center">
       Posiziono la tua attività in cima alle ricerche locali per farti scegliere prima di chiunque altro. </p>
    

  </div>
</section>

<style>
  .gb-section {
    position: relative;
    background: linear-gradient(180deg, transparent 0%, rgba(59,130,246,0.03) 50%, transparent 100%);
    overflow: hidden;
  }

  .gb-glow {
    position: absolute;
    width: 800px;
    height: 400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse, rgba(59,130,246,0.06) 0%, transparent 70%);
    pointer-events: none;
  }




  .text-maps {
    background: linear-gradient(135deg, #ea4335, #fbbc05, #34a853, #4285f4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .gb-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 64px;
  }

  .gb-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
    transition: all 0.25s ease;
  }

  .gb-card:hover {
    border-color: rgba(59,130,246,0.25);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
  }

  .gb-icon {
    width: 40px;
    height: 40px;
    background: rgba(59,130,246,0.12);
    color: #60a5fa;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .gb-card-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
  }

  .gb-card-desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── Map visual ── */
  .gb-visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 64px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .gb-map-mock {
    position: relative;
    height: 300px;
    /* FIX: overflow visible così il popup non viene tagliato,
       ma solo se il pin è dentro i limiti verticali */
    overflow: hidden;
  }

  .map-bg {
    position: absolute;
    inset: 0;
    background: #1a2332;
  }

  .map-road {
    position: absolute;
    background: rgba(255,255,255,0.08);
  }

  .map-road-h { left: 0; right: 0; height: 8px; }
  .map-road-v { top: 0; bottom: 0; width: 8px; }
  .map-road.thin { height: 3px; }
  .map-road-v.thin { width: 3px; }

  /* ── FIX PRINCIPALE: pin posizionato più in basso ──
     Il popup (.pin-card) si apre SOPRA il pin, quindi
     serve spazio sopra: spostiamo il punto ancora a metà mappa
     e l'intera struttura va dall'alto in basso:
     [pin-card] → [freccia] → [pin-icon]
     top: 55% garantisce che il popup abbia spazio sopra
  ── */
  .map-pin {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
  }

  .main-pin {
    /* Centro orizzontale, verticalmente a metà-bassa così il popup
       "La Tua Attività" non viene tagliato in alto */
    top: 40%;
    left: 42%;
    transform: translateX(-50%);
  }


  .pin-card {
    background: white;
    border-radius: 8px;
    padding: 8px 12px;
    min-width: 140px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    margin-bottom: 2px;
  }

  /* Freccetta tra popup e pin */
  .pin-card-arrow {
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 7px solid white;
    margin-bottom: 1px;
    filter: drop-shadow(0 2px 2px rgba(0,0,0,0.15));
  }

  .pin-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2px;
  }

  .pin-card-name {
    font-size: 12px;
    font-weight: 700;
    color: #111;
  }

  .pin-card-rating {
    font-size: 11px;
    color: #f59e0b;
    font-weight: 600;
  }

  .pin-card-cat {
    font-size: 10px;
    color: #4285f4;
    font-weight: 500;
  }

  /* Pin icona sotto il popup */
  .pin-icon {
    width: 40px;
    height: 40px;
    background: #4285f4;
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(66,133,244,0.5);
    animation: pinBounce 2s ease-in-out infinite;
  }

  .pin-icon svg { transform: rotate(45deg); }

  @keyframes pinBounce {
    0%, 100% { transform: rotate(-45deg) translateY(0); }
    50% { transform: rotate(-45deg) translateY(-4px); }
  }

  .secondary-pin {
    position: absolute;
  }

  .pin-icon-sm {
    width: 16px;
    height: 16px;
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
  }

  .pin-icon-sm.red { background: #ea4335; opacity: 0.6; }

  /* Results panel */
  .gb-results {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: center;
  }

  .gbr-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 4px;
  }

  .gbr-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: border-color 0.2s;
  }

  .gbr-item--first {
    border-color: rgba(59,130,246,0.3);
    background: rgba(59,130,246,0.07);
  }

  .gbr-pos {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 800;
    color: var(--blue);
    min-width: 28px;
  }

  .gbr-pos.muted { color: var(--text-subtle); font-size: 15px; }

  .gbr-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2px;
  }

  .gbr-name.muted { color: var(--text-muted); font-weight: 400; }

  .gbr-info {
    font-size: 12px;
    color: var(--text-subtle);
  }

  .gbr-badge {
    margin-left: auto;
    background: rgba(59,130,246,0.15);
    border: 1px solid rgba(59,130,246,0.3);
    color: var(--blue-light);
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .gb-cta {
    text-align: center;
  }

  .gb-cta-note {
    margin-top: 12px;
    font-size: 13px;
    color: var(--text-subtle);
  }

  /* ── Breakpoint 900px ── */
  @media (max-width: 900px) {
    .gb-grid { grid-template-columns: repeat(2, 1fr); }
    .gb-visual {
      grid-template-columns: 1fr;
    }
    .gb-map-mock {
      height: 260px;
    }
    .main-pin {
      top: 50%;
      left: 50%;
    }
  }

  /* ── Breakpoint 580px ── */
  @media (max-width: 580px) {
    .gb-grid { grid-template-columns: 1fr; }
    .gb-card { flex-direction: column; }
    .gb-map-mock { height: 240px; }
    .main-pin {
      top: 25%;
      left: 50%;
    }
    /* Pin card più compatta su schermi piccoli */
    .pin-card {
      min-width: 120px;
      padding: 6px 10px;
    }
    .pin-card-name { font-size: 11px; }
    .pin-card-cat  { font-size: 9px; }
    .pin-icon { width: 34px; height: 34px; }
  }
</style>