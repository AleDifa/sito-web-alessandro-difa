<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <a href="/" class="nav-logo">
        <span class="nav-logo-icon">
          <img src="/img/logo-adf.png" alt="Logo ADF" class="nav-logo-img">
        </span>
        <span class="nav-logo-text">Alessandro Difa</span>
      </a>

         <div class="contact-socials">
          <a href="https://www.linkedin.com/in/alessandro-difa/" class="social-link" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://www.instagram.com/alessandro_difa/" class="social-link" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://medium.com/@alessandro-difa" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Medium">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </a>
          <a href="https://www.youtube.com/@alessandrodifa" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="YouTube">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"> <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
         </a>
        </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 28px 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

 .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px; /* Spazio orizzontale tra il logo ADF e il testo */
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
}

.nav-logo-icon {
      height: 52px;      
    display: flex;
    align-items: center;
}

.nav-logo-icon img {
    height: 100%;      
    width: auto;       
    display: block;
    object-fit: contain;
}

.nav-logo-text {
    white-space: nowrap; 
    display: flex;
    align-items: center;
}
  .footer-socials {
    display: flex;
    gap: 8px;
  }

.contact-socials {
  display: flex !important;       
  flex-direction: row !important; 
  gap: 12px;                      
  margin-top: 20px;               
}

  .social-link {
    width: 34px;
    height: 34px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.2s;
  }

  .social-link:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }

  @media (max-width: 600px) {
    .footer-inner { justify-content: center; text-align: center; flex-direction: column; }
  }
</style>
