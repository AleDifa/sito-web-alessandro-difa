---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Web Design, siti Web SEO & GEO ad Ancona | Reputazione Online 360° - Alessandro DiFa",
  description = "Creazione siti web performanti ottimizzati per SEO e GEO (AI), gestisco Google Business Profile e la reputazione online della tua azienda per farti trovare prima dei competitor, vendi di più.",
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Alessandro DiFa - Siti Web, SEO & Reputazione Online",
  "image": "https://alessandrodifa.com/immagine-profilo.jpg",
  "description": description,
  "url": "https://alessandrodifa.com",
  "telephone": "+39 392 4588449",
  "email": "alessandro.difa93@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Ancona",
    "addressRegion": "Marche",
    "addressCountry": "IT"
  },
  "areaServed": [
    { "@type": "City", "name": "Ancona" },
    { "@type": "State", "name": "Marche" }
  ],
  "serviceType": [
    "Sviluppo Siti Web",
    "SEO",
    "GEO (Generative Engine Optimization)",
    "Google Business Profile",
    "Gestione Reputazione Online Locale"
  ],
  "priceRange": "€€",
  "sameAs": [
    "https://www.linkedin.com/in/alessandro-difa/",
    "https://www.instagram.com/alessandro_difa/"
  ]
};
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="it_IT" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <!-- Canonical -->
    <link rel="canonical" href="https://alessandrodifa.com/" />
    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>